# Non-secret behavior configuration for the generic harness.

DEV_AGENT_CMD=claude
# Run `vibe agent` inside a persistent tmux session (reattach by rerunning it).
DEV_AGENT_TMUX=1
# Session `vibe attach` opens when called without a name — e.g. a services
# session your project/post-start.sh stands up. Unset -> "main".
#DEV_ATTACH_TMUX_SESSION=services
DEV_BOOTSTRAP_STRICT=1
DEV_AUTO_INSTALL=1
DEV_AUTO_GIT_HOOKS=1
DEV_AUTO_GIT_LFS=1
DEV_ENV_FILE=.env
DEV_REQUIRED_COMMANDS="git gh jq rg uv claude@EXTRA_COMMANDS@"

# Image viewer (tmux "preview" window: prefix+i; Claude Code hooks feed it).
# Directory watched for new images and space-separated glob list — the glob
# only filters which files are WATCHED; at render time the real format is
# sniffed from file content, never the extension. The viewer is PASSIVE by
# default (look at clips/pastes, no verdicts). Setting
# VIBE_PREVIEW_DECISIONS switches every instance to review mode: y/n record
# approve/reject (reject offers an optional note) to that JSONL for an agent
# or pipeline to consume. For per-batch review without config, use
# `vibe review <dir>` instead (verdicts land in <dir>/vibe-decisions.jsonl).
VIBE_PREVIEW_DIR=/tmp
VIBE_PREVIEW_GLOB="*.png *.jpg *.jpeg *.gif *.bmp *.webp *.avif"
#VIBE_PREVIEW_DECISIONS=/workspaces/myproject/renders/vibe-decisions.jsonl
