#!/usr/bin/env bash
set -euo pipefail

# This launcher normally runs as .devcontainer/harness/vibe inside a consuming
# project (the seeded .devcontainer/vibe wrapper execs it), but it also works
# from the host PATH (e.g. symlinked into ~/.local/bin). The target project is
# the nearest ancestor of $PWD with a .devcontainer/devcontainer.json; when
# $PWD is outside any project, it falls back to the project this script lives
# in (two levels up, after resolving symlinks).
# Resolve symlinks with a loop rather than `readlink -f` (GNU-only; stock macOS
# readlink lacks -f). Follows each link hop; the trailing `cd`+`pwd` canonicalizes.
self_path="${BASH_SOURCE[0]}"
while [ -L "$self_path" ]; do
  link_target="$(readlink "$self_path")"
  case "$link_target" in
    /*) self_path="$link_target" ;;
    *)  self_path="$(dirname -- "$self_path")/$link_target" ;;
  esac
done
self_dir="$(cd -- "$(dirname -- "$self_path")" && pwd)"

# shellcheck source=scripts/repo-root.sh disable=SC1091
. "$self_dir/scripts/repo-root.sh"
repo_root="$(find_repo_root_from_pwd || true)"
if [[ -z "$repo_root" ]]; then
  fallback_root="$(cd -- "$self_dir/../.." && pwd)"
  if [[ -f "$fallback_root/.devcontainer/devcontainer.json" ]]; then
    repo_root="$fallback_root"
  fi
fi

if [[ -z "$repo_root" ]]; then
  echo "No .devcontainer/devcontainer.json found above: $PWD" >&2
  echo "Run from inside a project set up with install.sh (or via its .devcontainer/vibe)." >&2
  exit 1
fi

# `vibe update` needs only git — dispatch it before the devcontainer-CLI check
# below so it also works from inside the container, where an agent has git but
# neither npx nor docker (update.sh prints the rebuild handoff instead).
if [ "${1:-}" = "update" ]; then
  shift
  VIBE_REPO_ROOT="$repo_root" exec bash "$self_dir/scripts/update.sh" "$@"
fi

# Pin the npx fallback: `@devcontainers/cli` (unversioned) resolves the mutable
# latest and runs it as the host user, so a bad release would execute with
# access to the host home, SSH keys, and Docker. Prefer a locally installed CLI;
# bump this pin deliberately. Override with DEVCONTAINER_CLI_SPEC if you must.
DEVCONTAINER_CLI_SPEC="${DEVCONTAINER_CLI_SPEC:-@devcontainers/cli@0.87.0}"
if command -v devcontainer >/dev/null 2>&1; then
  cli=(devcontainer)
elif command -v npx >/dev/null 2>&1; then
  cli=(npx -y "$DEVCONTAINER_CLI_SPEC")
else
  echo "Install @devcontainers/cli or Node/npx on the WSL host." >&2
  echo "Example: npm install -g @devcontainers/cli" >&2
  exit 1
fi

# The devcontainer CLI labels containers with the workspace path it started
# them from; an empty `docker ps` match means stopped or never created. Hosts
# without a docker client (e.g. podman) fall back to probing with a no-op exec.
container_running() {
  if command -v docker >/dev/null 2>&1; then
    [[ -n "$(docker ps -q --filter "label=devcontainer.local_folder=$repo_root" 2>/dev/null)" ]]
  else
    "${cli[@]}" exec --workspace-folder "$repo_root" true >/dev/null 2>&1
  fi
}

# Container commands start the container when it isn't running, so `vibe agent`
# works cold. Progress goes to stderr to keep stdout clean for `vibe run` pipes.
ensure_up() {
  if ! container_running; then
    echo "Container not running for $repo_root — starting it..." >&2
    "${cli[@]}" up --workspace-folder "$repo_root" 1>&2
  fi
}

command_name="${1:-help}"
if (($#)); then
  shift
fi

case "$command_name" in
  up)
    exec "${cli[@]}" up --workspace-folder "$repo_root" "$@"
    ;;
  rebuild)
    exec "${cli[@]}" up --workspace-folder "$repo_root" --remove-existing-container "$@"
    ;;
  build)
    exec "${cli[@]}" build --workspace-folder "$repo_root" "$@"
    ;;
  status)
    # Host-side: list this project's container(s) by the devcontainer CLI's
    # workspace label. Needs a docker client — the CLI has no ps of its own.
    command -v docker >/dev/null 2>&1 || { echo "vibe status needs a docker client on the host." >&2; exit 1; }
    exec docker ps -a --filter "label=devcontainer.local_folder=$repo_root" \
      --format 'table {{.Names}}\t{{.Status}}\t{{.Image}}\t{{.Ports}}'
    ;;
  down)
    # Stop & remove this project's container. Named volumes (agent state) are
    # untouched — only the container goes; `vibe up` recreates it.
    command -v docker >/dev/null 2>&1 || { echo "vibe down needs a docker client on the host." >&2; exit 1; }
    ids="$(docker ps -aq --filter "label=devcontainer.local_folder=$repo_root")"
    [[ -n "$ids" ]] || { echo "No container found for $repo_root" >&2; exit 0; }
    # shellcheck disable=SC2086  # one id per word is the point
    exec docker rm -f $ids
    ;;
  attach)
    # Attach (or create) a tmux session in the container — the door into a
    # long-lived services session a project's post-start hook stands up.
    # Session name: argument > DEV_ATTACH_TMUX_SESSION in config.env > "main".
    ensure_up
    exec "${cli[@]}" exec --workspace-folder "$repo_root" \
      bash .devcontainer/harness/scripts/agent-entry.sh attach "$@"
    ;;
  shell)
    ensure_up
    exec "${cli[@]}" exec --workspace-folder "$repo_root" bash "$@"
    ;;
  agent)
    ensure_up
    # All agent logic (flag parsing, DEV_AGENT_CMD resolution, tmux wrapping)
    # lives container-side in agent-entry.sh, which gets real argv via exec —
    # no payload string, no re-quoting on this side of the boundary.
    exec "${cli[@]}" exec --workspace-folder "$repo_root" \
      bash .devcontainer/harness/scripts/agent-entry.sh agent "$@"
    ;;
  doctor)
    ensure_up
    exec "${cli[@]}" exec --workspace-folder "$repo_root" \
      bash .devcontainer/harness/scripts/doctor.sh "$@"
    ;;
  bootstrap)
    ensure_up
    exec "${cli[@]}" exec --workspace-folder "$repo_root" \
      bash .devcontainer/harness/scripts/post-create.sh "$@"
    ;;
  run)
    (($#)) || { echo "Usage: vibe run COMMAND [ARGUMENT ...]" >&2; exit 2; }
    ensure_up
    exec "${cli[@]}" exec --workspace-folder "$repo_root" \
      .devcontainer/harness/scripts/env-run.sh "$@"
    ;;
  exec)
    (($#)) || { echo "Usage: vibe exec COMMAND [ARGUMENT ...]" >&2; exit 2; }
    ensure_up
    exec "${cli[@]}" exec --workspace-folder "$repo_root" "$@"
    ;;
  show)
    # Preview an image (default: newest `vibe clip` capture) in the invoking
    # terminal — the agent TUI can't render images inline. `--diag PATH`
    # explains a failing render instead of drawing it.
    ensure_up
    exec "${cli[@]}" exec --workspace-folder "$repo_root" \
      bash .devcontainer/harness/scripts/show-image.sh "$@"
    ;;
  review)
    # yazi in the INVOKING terminal (prefix+i inside the agent session opens
    # the same thing as a dedicated tmux window). The harness binds A=approve
    # and R=reject-with-note (vibe.yazi plugin; verdicts land in
    # .review-decisions.jsonl beside the images); the project-owned
    # .devcontainer/yazi/ layers preferences and rebinds on top.
    ensure_up
    exec "${cli[@]}" exec --workspace-folder "$repo_root" \
      bash .devcontainer/harness/scripts/review.sh "$@"
    ;;
  clip)
    # Host-side: grabs the OS clipboard image; container /tmp by default, or a
    # workspace-relative directory when given (vibe clip .captures). Workspace
    # mode writes straight to the bind mount, so only the /tmp streaming path
    # (no DIR) needs a running container.
    [ -n "${1:-}" ] || ensure_up
    exec bash "$self_dir/scripts/host/clip-image.sh" "$repo_root" "${1:-}" "${cli[@]}"
    ;;
  help|-h|--help)
    cat <<'HELP'
Usage: vibe COMMAND [ARGUMENT ...]

Commands:
  up          Build/start the Dev Container
  rebuild     Recreate the container (picks up devcontainer.json/Dockerfile edits)
  build       Build the Dev Container image
  status      Show this project's container(s)
  down        Stop & remove this project's container (named volumes are kept)
  update [TAG]  Move the harness pin to TAG (default: newest release): fetch,
              show changelog delta + diff, checkout, stage — commit & rebuild stay yours
  shell       Open a Bash shell in the container
  attach      Attach/create a tmux session in the container
              (SESSION argument > DEV_ATTACH_TMUX_SESSION > "main")
  agent       Run the configured default agent with explicit .env loading
              (--cold: skip CLAUDE.md/AGENTS.md and .claude customizations;
               -a/--agent CMD: run CMD instead of DEV_AGENT_CMD, e.g. -a codex)
  run         Run any command with explicit .env loading (e.g. vibe run grok)
  doctor      Check the active environment
  bootstrap   Rerun create-time dependency setup
  exec        Run an arbitrary command in the container (no .env loading)
  clip        Save the host clipboard image for the container: /tmp, or DIR in the workspace
  show        Preview an image in the terminal (default: newest vibe clip capture)
              (--diag PATH: report format/renderer/error instead of drawing)
  review [DIR]  Browse/review images with yazi; A approves, R rejects (with
              optional note) to .review-decisions.jsonl beside the images
HELP
    ;;
  *)
    echo "Unknown command: $command_name" >&2
    exit 2
    ;;
esac
