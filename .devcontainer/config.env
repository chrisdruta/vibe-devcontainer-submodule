# Non-secret behavior configuration for the generic harness.

DEV_AGENT_CMD=claude
# Run `vibe agent` inside a persistent tmux session (reattach by rerunning it).
DEV_AGENT_TMUX=1
DEV_BOOTSTRAP_STRICT=1
DEV_AUTO_INSTALL=1
DEV_AUTO_GIT_HOOKS=1
DEV_AUTO_GIT_LFS=1
DEV_ENV_FILE=.env
DEV_REQUIRED_COMMANDS="git gh jq rg uv claude"

# Image review viewer (tmux "preview" window: prefix+i; Claude Code hooks feed
# it). Directory watched for new images, space-separated glob list, and the
# JSONL verdict log (default: vibe-decisions.jsonl inside VIBE_PREVIEW_DIR --
# point both at your render-output directory to review batches in place).
VIBE_PREVIEW_DIR=/tmp
VIBE_PREVIEW_GLOB="*.png *.jpg *.jpeg *.gif *.bmp *.webp *.avif"
#VIBE_PREVIEW_DECISIONS=/workspaces/myproject/renders/vibe-decisions.jsonl
